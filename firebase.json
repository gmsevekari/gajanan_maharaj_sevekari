{
    "flutter": {
        "platforms": {
            "android": {
                "default": {
                    "projectId": "app-event-calendar",
                    "appId": "1:33491188906:android:cdea10b7acfc04b7c6e4d3",
                    "fileOutput": "android/app/google-services.json"
                }
            },
            "ios": {
                "default": {
                    "projectId": "app-event-calendar",
                    "appId": "1:33491188906:ios:a1044949e445b36dc6e4d3",
                    "uploadDebugSymbols": false,
                    "fileOutput": "ios/Runner/GoogleService-Info.plist"
                }
            },
            "dart": {
                "lib/firebase_options.dart": {
                    "projectId": "app-event-calendar",
                    "configurations": {
                        "android": "1:33491188906:android:cdea10b7acfc04b7c6e4d3",
                        "ios": "1:33491188906:ios:a1044949e445b36dc6e4d3"
                    }
                }
            }
        }
    },
    "hosting": {
        "public": "build/web",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ],
        "headers": [
            {
                "source": "/.well-known/apple-app-site-association",
                "headers": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ]
            }
        ]
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "disallowLegacyRuntimeConfig": true,
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ]
        }
    ]
}