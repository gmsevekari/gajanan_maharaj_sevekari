rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for role-based access
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email_verified == true &&
             exists(/databases/$(database)/documents/admin_allowlist/$(request.auth.token.email));
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/admin_allowlist/$(request.auth.token.email)).data;
    }

    function isSuperAdmin() {
      return isAdmin() && getAdminData().roles.hasAny(['super_admin']);
    }

    // Bounds a non-admin totalSteps/totalDistance counter update to a single,
    // plausible, forward-only increment — preventing a modified client from
    // inflating (or reversing) shared Vaari counters in one write.
    function isValidVaariCounterIncrement(before, after) {
      let maxStepsPerSubmission = 100000;
      let maxDistancePerSubmission = 500;
      return after.totalSteps is number &&
             after.totalDistance is number &&
             after.totalSteps > before.totalSteps &&
             after.totalSteps - before.totalSteps <= maxStepsPerSubmission &&
             after.totalDistance > before.totalDistance &&
             after.totalDistance - before.totalDistance <= maxDistancePerSubmission;
    }

    // App Config: Publicly readable; Admin writable
    match /app_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin Allowlist: Read/Write rules for administrators
    match /admin_allowlist/{email} {
      // Individual document access
      allow get: if request.auth != null && (request.auth.token.email == email || isAdmin());

      // Secure listing: Allow super_admin to see all, group_admin to see their own group
      // Using direct get() in list rule is more robust for query verification
      allow list: if request.auth != null && isAdmin() && (
        get(/databases/$(database)/documents/admin_allowlist/$(request.auth.token.email)).data.roles.hasAny(['super_admin']) ||
        (
          get(/databases/$(database)/documents/admin_allowlist/$(request.auth.token.email)).data.roles.hasAny(['group_admin']) &&
          get(/databases/$(database)/documents/admin_allowlist/$(request.auth.token.email)).data.groupId != null &&
          resource.data.groupId == get(/databases/$(database)/documents/admin_allowlist/$(request.auth.token.email)).data.groupId
        )
      );

      // Split write rules to avoid invalid request.method and prevent privilege escalation
      allow create: if isSuperAdmin() || (
        isAdmin() &&
        getAdminData().roles.hasAny(['group_admin']) &&
        getAdminData().groupId != null &&
        request.resource.data.groupId == getAdminData().groupId &&
        !request.resource.data.roles.hasAny(['super_admin']) &&
        request.resource.data.keys().hasOnly(['roles', 'groupId', 'typoNotificationsEnabled']) &&
        request.resource.data.roles is list &&
        (request.resource.data.groupId == null || request.resource.data.groupId is string) &&
        (!('typoNotificationsEnabled' in request.resource.data) || request.resource.data.typoNotificationsEnabled is bool)
      );

      allow update: if isSuperAdmin() || (
        isAdmin() &&
        getAdminData().roles.hasAny(['group_admin']) &&
        getAdminData().groupId != null &&
        resource.data.groupId == getAdminData().groupId &&
        (request.resource.data.groupId == getAdminData().groupId || request.resource.data.groupId == null) &&
        !resource.data.roles.hasAny(['super_admin']) && // Prevent demoting super admin
        !request.resource.data.roles.hasAny(['super_admin']) &&
        request.resource.data.keys().hasOnly(['roles', 'groupId', 'typoNotificationsEnabled']) &&
        request.resource.data.roles is list &&
        (request.resource.data.groupId == null || request.resource.data.groupId is string) &&
        (!('typoNotificationsEnabled' in request.resource.data) || request.resource.data.typoNotificationsEnabled is bool) &&
        // Prevent editing own document to escalate roles or modify groupId
        (email != request.auth.token.email || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'groupId']))
      );

      allow delete: if isSuperAdmin() || (
        isAdmin() &&
        getAdminData().roles.hasAny(['group_admin']) &&
        getAdminData().groupId != null &&
        resource.data.groupId == getAdminData().groupId &&
        !resource.data.roles.hasAny(['super_admin']) && // Prevent deleting super admin
        // Prevent deleting own admin record
        email != request.auth.token.email
      );
    }

    // Typo Reports: Validated fields/types/sizes; Admin readable/deletable
    match /typo_reports/{reportId} {
      allow create: if request.resource.data.keys().hasOnly([
        'contentPath', 'contentTitle', 'contentType', 'deityId',
        'typoText', 'suggestedCorrection', 'deviceId', 'timestamp'
      ])
      && request.resource.data.contentPath is string
      && request.resource.data.contentPath.size() < 500
      && request.resource.data.contentTitle is string
      && request.resource.data.contentTitle.size() < 500
      && request.resource.data.contentType is string
      && request.resource.data.contentType.size() < 100
      && request.resource.data.deityId is string
      && request.resource.data.deityId.size() < 100
      && request.resource.data.typoText is string
      && request.resource.data.typoText.size() < 2000
      && request.resource.data.suggestedCorrection is string
      && request.resource.data.suggestedCorrection.size() < 2000
      && request.resource.data.deviceId is string
      && request.resource.data.deviceId.size() < 200
      && request.resource.data.timestamp is timestamp;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // Admin Audit Logs: Admin create-only (append-only); Not readable via app
    match /admin_audit_logs/{logId} {
      allow read: if false;
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(['admin_email', 'action', 'details', 'timestamp', 'expires_at'])
        && request.resource.data.admin_email == request.auth.token.email
        && request.resource.data.admin_email.size() < 150
        && request.resource.data.action is string
        && request.resource.data.action.size() < 100
        && request.resource.data.timestamp is timestamp
        && request.resource.data.expires_at is timestamp
        && request.resource.data.details is map
        && request.resource.data.details.size() < 50;
      allow update, delete: if false;
    }

    // Parayan Events: Publicly readable; Admin writable
    match /parayan_events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();

      match /participants/{participantId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['name', 'memberName', 'assignedAdhyays', 'completions', 'joinedAt'])
          && request.resource.data.keys().hasOnly(['name', 'memberName', 'assignedAdhyays', 'completions', 'joinedAt', 'deviceId', 'phone', 'globalIndex', 'groupNumber', 'id'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() < 100
          && request.resource.data.memberName is string
          && request.resource.data.memberName.size() > 0
          && request.resource.data.memberName.size() < 100
          && request.resource.data.assignedAdhyays is list
          && request.resource.data.completions is map
          && request.resource.data.joinedAt is timestamp
          && (request.resource.data.get('deviceId', null) == null || (request.resource.data.get('deviceId', '') is string && request.resource.data.get('deviceId', '').size() < 200))
          && (request.resource.data.get('phone', null) == null || (request.resource.data.get('phone', '') is string && request.resource.data.get('phone', '').size() < 30))
          && (request.resource.data.get('globalIndex', null) == null || request.resource.data.get('globalIndex', 0) is int)
          && (request.resource.data.get('groupNumber', null) == null || request.resource.data.get('groupNumber', 0) is int);
        // Allows user to update completions locally using deviceId check. Identity/assignment fields remain immutable.
        allow update: if isAdmin() || (
          request.resource.data.deviceId == resource.data.deviceId &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.phone == resource.data.phone &&
          request.resource.data.assignedAdhyays == resource.data.assignedAdhyays &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completions'])
        );
        // Public deletion is intended: participants do not log in and must be able to delete their own registrations from the UI using their deviceId
        allow delete: if isAdmin() || (resource.data.deviceId != null);
      }
    }

    // Notifications: Publicly readable; Admin writable
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Legacy Events: Publicly readable
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Group Namjap Events: Publicly readable; Admin writable
    match /group_namjap_events/{eventId} {
      allow read: if true;
      // Allow atomic updates by participants to increment global counts
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalCount']))
                    || isAdmin();
      allow create, delete: if isAdmin();

      match /participants/{participantId} {
        allow read: if true;
        allow create: if true;
        // Allows user to update their own jap counts locally using deviceId check
        // Prevents changing identity fields (deviceId, memberName, phone) after creation
        allow update: if isAdmin() || (
          request.resource.data.deviceId == resource.data.deviceId &&
          request.resource.data.memberName == resource.data.memberName &&
          request.resource.data.phone == resource.data.phone &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalCount', 'dailyCounts'])
        );
        // Public deletion is intended: participants do not log in and must be able to delete their own registrations from the UI using their deviceId
        allow delete: if isAdmin() || (resource.data.deviceId != null);
      }
    }

    // Vaari Events: Publicly readable; Admin writable
    match /vaari_events/{eventId} {
      allow read: if true;
      // Only admins can create or delete events
      allow create, delete: if isAdmin();
      // Allow atomic updates by participants to increment global step/distance counters only,
      // bounded to a single plausible submission (see isValidVaariCounterIncrement)
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalSteps', 'totalDistance']) &&
        isValidVaariCounterIncrement(resource.data, request.resource.data)
      );

      match /participants/{participantId} {
        allow read: if true;
        // Any authenticated or anonymous user can register with valid fields
        allow create: if request.resource.data.keys().hasAll(['memberName', 'deviceId', 'phone', 'joinedAt', 'totalSteps', 'totalDistance'])
          && request.resource.data.keys().hasOnly(['memberName', 'deviceId', 'phone', 'joinedAt', 'totalSteps', 'totalDistance'])
          && request.resource.data.memberName is string
          && request.resource.data.memberName.size() > 0
          && request.resource.data.memberName.size() < 100
          && request.resource.data.deviceId is string
          && request.resource.data.deviceId.size() > 0
          && request.resource.data.deviceId.size() < 200
          && request.resource.data.phone is string
          && request.resource.data.phone.size() < 30
          && request.resource.data.joinedAt is timestamp
          && request.resource.data.totalSteps == 0
          && request.resource.data.totalDistance == 0.0;
        // Participants may only increment their own step/distance counts, bounded to a single
        // plausible submission (see isValidVaariCounterIncrement); identity fields are immutable
        allow update: if isAdmin() || (
          request.resource.data.deviceId == resource.data.deviceId &&
          request.resource.data.memberName == resource.data.memberName &&
          request.resource.data.phone == resource.data.phone &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalSteps', 'totalDistance']) &&
          isValidVaariCounterIncrement(resource.data, request.resource.data)
        );
        // Public deletion: participants do not log in and must be able to remove own registration via deviceId
        allow delete: if isAdmin() || (resource.data.deviceId != null);
      }
    }
  }
}
