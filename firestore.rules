rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Allow public read access to app configuration
    match /app_config/{document} {
      allow read: if true;
      allow write: if false; // Only allow writes from Admin/Console
    }
    
    // Keep your existing public event read access
    match /events/{eventId} {
      allow read: if true;
      allow write: if false; 
    }
    
    // Allow anyone to read notifications, but only let authenticated admins write them
    match /notifications/{document=**} {
      allow read: if true;
      allow write: if request.auth != null; 
    }
    
    // Allow the app to check if an email is in the allowlist during login
    match /admin_allowlist/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Allow authenticated admins to write audit logs, but nobody can read them via the app
    match /admin_audit_logs/{document=**} {
      allow read: if false;
      allow write: if request.auth != null;
    }
    
    match /parayan_events/{eventId} {
    	allow read: if true;
  		allow write: if request.auth != null;
  
  		match /participants/{deviceId} {
    		allow read, write: if true;
  		}
		}
  }
}
